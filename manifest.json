{
  "manifest_version": 3,
  "name": "D365 Edge Helper",
  "version": "0.1.0",
  "description": "Manage multiple Dynamics 365 F&O environments from your toolbar.",
  "icons": {
    "16":  "assets/icons/icon16.png",
    "32":  "assets/icons/icon32.png",
    "48":  "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "D365 Edge Helper"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.operations.dynamics.com/*"],
      "js": ["content/content_script.js"],
      "css": ["content/content_script.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "open-palette": {
      "suggested_key": {
        "default": "Alt+Shift+D"
      },
      "description": "Open D365 command palette"
    }
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ]
}
